# Supabase (skapa projekt på supabase.com, region eu-north-1)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# App config
VITE_APP_NAME=Crew2you
VITE_APP_ENV=development

# === Server-side only (Supabase Edge Functions) ===
# Anthropic API för AI-mailparsning och matchning
ANTHROPIC_API_KEY=sk-ant-...

# Resend för transactional mail
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bokning@crew2you.se

# 46elks för SMS
ELKS_USERNAME=
ELKS_PASSWORD=
ELKS_FROM=Crew2you

# Fortnox (Enterprise)
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
